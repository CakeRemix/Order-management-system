# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=order_management_system
DB_USER=postgres
DB_PASSWORD=0000

# Application Configuration
APP_NAME=Order Management System
APP_ENV=development
APP_DEBUG=true
APP_PORT=3000
APP_HOST=localhost

# JWT Authentication
JWT_SECRET=0000
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
EMAIL_FROM=noreply@ordermanagementsystem.com

# Payment Gateway (if integrated in future)
# PAYMENT_GATEWAY_API_KEY=your_payment_gateway_key
# PAYMENT_GATEWAY_SECRET=your_payment_gateway_secret 

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads 

# Session Configuration
SESSION_SECRET=your_session_secret_here
SESSION_TIMEOUT=1800000

# API Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# Security
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:3000

# Admin Default Credentials (change after first login)
ADMIN_EMAIL=admin@ordermanagementsystem.com
ADMIN_PASSWORD=AdminPassword123!

# Google Maps API (for location services)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Notification Service
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false